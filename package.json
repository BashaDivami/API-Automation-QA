{
  "name": "shopeasy-api-automation",
  "version": "1.0.0",
  "description": "API Automation Testing Suite for ShopEasy Order Management API",
  "scripts": {
    "test": "jest --runInBand --forceExit",
    "test:auth": "jest --testPathPattern=auth --runInBand --forceExit",
    "test:products": "jest --testPathPattern=products --runInBand --forceExit",
    "test:cart": "jest --testPathPattern=cart --runInBand --forceExit",
    "test:orders": "jest --testPathPattern=orders --runInBand --forceExit",
    "test:payments": "jest --testPathPattern=payments --runInBand --forceExit",
    "test:e2e": "jest --testPathPattern=e2e --runInBand --forceExit",
    "test:ci": "jest --runInBand --forceExit --reporters=default --reporters=jest-junit",
    "report": "open reports/execution/test-report.html",
    "coverage-report": "open reports/coverage/api-coverage.html"
  },
  "devDependencies": {
    "axios": "^1.7.9",
    "dotenv": "^16.4.5",
    "jest": "^29.7.0",
    "jest-html-reporter": "^3.10.2",
    "jest-junit": "^16.0.0"
  }
}
